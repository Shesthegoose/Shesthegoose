<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>She's the Goose — A Curated Life, Well Lived</title>
<meta name="description" content="She's the Goose is a curated edit of the pieces and products that have genuinely improved the way I live — chosen carefully, recommended honestly, linked so you can find them without the work.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Jost:wght@200;300;400&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #F5F0E8;
    --warm-white: #FAFAF7;
    --ink: #1E1A14;
    --ink-mid: #2E2820;
    --ink-light: #4A4234;
    --stone: #8C7E6E;
    --stone-light: #B5A898;
    --terracotta: #96624A;
    --sage: #6A7A62;
    --blush: #C8A090;
    --border: #DDD5C8;
    --border-dark: #3A3028;
    --serif: 'Cormorant Garamond', Georgia, serif;
    --sans: 'Jost', sans-serif;
    --navy: #16181F;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { background: var(--cream); color: var(--ink); font-family: var(--serif); -webkit-font-smoothing: antialiased; overflow-x: hidden; }

  /* ───── NAV ───── */
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.4rem 4vw;
    border-bottom: 1px solid var(--border);
    background: var(--warm-white);
    position: sticky;
    top: 0;
    z-index: 200;
  }
  .nav-logo {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: .04em;
    color: var(--ink);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    line-height: 1.25;
  }
  .nav-logo span {
    font-family: var(--sans);
    font-size: .52rem;
    font-weight: 200;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--stone);
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }
  .nav-links {
    display: flex;
    gap: 2.2rem;
    list-style: none;
  }
  .nav-links a {
    font-family: var(--sans);
    font-size: .65rem;
    font-weight: 300;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--ink-light);
    text-decoration: none;
    transition: color .2s;
  }
  .nav-links a:hover { color: var(--terracotta); }
  .nav-sister a {
    font-family: var(--sans);
    font-size: .62rem;
    font-weight: 300;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--sage);
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 1px solid var(--sage);
    transition: opacity .2s;
  }
  .nav-sister a:hover { opacity: .7; }

  /* ───── HERO ───── */
  .hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('IMG_1719.jpeg');
    background-size: cover;
    background-position: center 30%;
    transform: scale(1.03);
    transition: transform 8s ease;
  }
  .hero-bg.loaded { transform: scale(1); }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(15,12,8,.15) 0%,
      rgba(15,12,8,.25) 40%,
      rgba(15,12,8,.65) 100%
    );
  }
  .hero-brand {
    position: absolute;
    top: 0;
    left: 0;
    padding: 0;
    font-family: var(--sans);
    font-size: .54rem;
    font-weight: 200;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: rgba(255,255,255,.55);
  }
  .hero-content {
    position: relative;
    z-index: 2;
    padding: 0 5vw 5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .hero-eyebrow {
    font-family: var(--sans);
    font-size: .54rem;
    font-weight: 200;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: rgba(255,255,255,.55);
    margin-bottom: 1.5rem;
  }
  .hero-headline {
    font-family: var(--serif);
    font-size: clamp(3.2rem, 6.5vw, 7rem);
    font-weight: 300;
    line-height: 1.06;
    color: #fff;
    margin-bottom: 2.5rem;
  }
  .hero-headline em {
    font-style: italic;
    color: var(--blush);
  }
  .hero-cta {
    font-family: var(--sans);
    font-size: .6rem;
    font-weight: 300;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: rgba(255,255,255,.75);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: .6rem;
    transition: color .25s;
  }
  .hero-cta::after { content: '↓'; font-family: var(--serif); font-size: .9rem; }
  .hero-cta:hover { color: #fff; }

  /* ───── SECTION SHARED ───── */
  .section-eyebrow {
    font-family: var(--sans);
    font-size: .54rem;
    font-weight: 300;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--stone);
    display: block;
    margin-bottom: 1.6rem;
  }

  /* ───── RIGHT NOW / SPRING ───── */
  .spring-section {
    background: var(--warm-white);
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 80vh;
  }
  .spring-image {
    position: relative;
    overflow: hidden;
  }
  .spring-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .spring-content {
    padding: 5rem 5vw 5rem 4rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .spring-content h2 {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 3.5vw, 3.8rem);
    font-weight: 300;
    line-height: 1.1;
    color: var(--ink);
    margin-bottom: 1.2rem;
  }
  .spring-content h2 em { font-style: italic; }
  .spring-content > p {
    font-family: var(--serif);
    font-size: .98rem;
    font-weight: 300;
    color: var(--ink-light);
    line-height: 1.85;
    margin-bottom: 2.8rem;
    max-width: 420px;
  }
  .spring-label {
    font-family: var(--sans);
    font-size: .54rem;
    font-weight: 200;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--stone-light);
    margin-bottom: .9rem;
    display: block;
  }
  .product-list { list-style: none; }
  .product-list li {
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: .9rem 0;
  }
  .product-list li:last-child { border-bottom: 1px solid var(--border); }
  .product-list .item-name {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 300;
    color: var(--ink);
    text-decoration: none;
  }
  .product-list .item-link {
    font-family: var(--sans);
    font-size: .52rem;
    font-weight: 300;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--stone);
    text-decoration: none;
    transition: color .2s;
  }
  .product-list .item-link:hover { color: var(--terracotta); }
  .spring-footer {
    margin-top: 2.2rem;
    font-family: var(--sans);
    font-size: .58rem;
    font-weight: 300;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--terracotta);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    border-bottom: 1px solid var(--terracotta);
    padding-bottom: 2px;
    transition: opacity .2s;
  }
  .spring-footer:hover { opacity: .65; }

  /* ───── BRAND STATEMENT ───── */
  .brand-statement {
    background: var(--cream);
    padding: 8rem 4vw;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 900px;
    margin: 0 auto;
  }
  .brand-statement h2 {
    font-family: var(--serif);
    font-size: clamp(2.6rem, 5vw, 5.5rem);
    font-weight: 300;
    line-height: 1.08;
    color: var(--ink);
    margin-bottom: 2.2rem;
  }
  .brand-statement h2 em { font-style: italic; color: var(--terracotta); }
  .brand-statement p {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 300;
    font-style: italic;
    color: var(--ink-light);
    line-height: 1.85;
    max-width: 600px;
    margin-bottom: 2.5rem;
  }
  .brand-about-link {
    font-family: var(--sans);
    font-size: .58rem;
    font-weight: 300;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--ink-light);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 2px;
    transition: border-color .2s, color .2s;
  }
  .brand-about-link:hover { color: var(--terracotta); border-color: var(--terracotta); }

  /* ───── KITCHEN SECTION ───── */
  .kitchen-section {
    background: var(--warm-white);
    padding-bottom: 0;
  }
  .kitchen-header {
    padding: 5rem 5vw 3rem;
  }
  .kitchen-header h2 {
    font-family: var(--serif);
    font-size: clamp(2.4rem, 5vw, 5rem);
    font-weight: 300;
    line-height: 1.1;
    color: var(--ink);
  }
  .kitchen-header h2 em { font-style: italic; }
  .kitchen-hero-img {
    width: 100%;
    height: 55vh;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }
  .kitchen-products {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    background: var(--border);
    margin-top: 2px;
  }
  .kitchen-product-card {
    background: var(--warm-white);
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 340px;
  }
  .kitchen-product-card.full {
    grid-column: 1 / -1;
    grid-template-columns: 1fr 1fr;
  }
  .k-card-img {
    overflow: hidden;
  }
  .k-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform .6s ease;
  }
  .k-card-img:hover img { transform: scale(1.03); }
  .k-card-text {
    padding: 2.8rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .k-card-badge {
    font-family: var(--sans);
    font-size: .52rem;
    font-weight: 300;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--stone);
    margin-bottom: .6rem;
    display: block;
  }
  .k-card-text h3 {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--ink);
    line-height: 1.2;
    margin-bottom: .8rem;
  }
  .k-card-text p {
    font-family: var(--serif);
    font-size: .9rem;
    font-weight: 300;
    color: var(--ink-light);
    line-height: 1.8;
    flex: 1;
  }
  .k-card-note {
    font-family: var(--serif);
    font-size: .85rem;
    font-weight: 300;
    font-style: italic;
    color: var(--terracotta);
    margin: 1rem 0;
  }
  .k-card-cta {
    font-family: var(--sans);
    font-size: .56rem;
    font-weight: 300;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--terracotta);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: .3rem;
    border-bottom: 1px solid var(--terracotta);
    padding-bottom: 2px;
    align-self: flex-start;
    transition: opacity .2s;
  }
  .k-card-cta:hover { opacity: .65; }
  .kitchen-link {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2.8rem;
    font-family: var(--sans);
    font-size: .62rem;
    font-weight: 300;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--stone);
    text-decoration: none;
    border-top: 1px solid var(--border);
    background: var(--warm-white);
    transition: color .2s;
  }
  .kitchen-link:hover { color: var(--terracotta); }

  /* ───── TRUST SECTION ───── */
  .trust-section {
    background: var(--cream);
    padding: 8rem 5vw;
  }
  .trust-inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .trust-inner h2 {
    font-family: var(--serif);
    font-size: clamp(2.4rem, 5vw, 5.2rem);
    font-weight: 300;
    line-height: 1.1;
    color: var(--ink);
    margin-bottom: 2.2rem;
  }
  .trust-inner h2 em { font-style: italic; }
  .trust-inner .trust-body {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 300;
    color: var(--ink-light);
    line-height: 1.9;
    max-width: 660px;
    margin-bottom: 1.5rem;
  }
  .trust-sig {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 300;
    font-style: italic;
    color: var(--stone);
    margin-bottom: 4rem;
    padding-top: .5rem;
    border-top: 1px solid var(--border);
    display: inline-block;
  }
  .trust-pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    border-top: 1px solid var(--border);
    padding-top: 2.5rem;
  }
  .pillar-label {
    font-family: var(--sans);
    font-size: .52rem;
    font-weight: 200;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--stone-light);
    margin-bottom: .6rem;
    display: block;
  }
  .pillar-text {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 300;
    color: var(--ink);
  }

  /* ───── QUIET LEDGER ───── */
  .quiet-section {
    background: var(--navy);
    padding: 7rem 5vw;
    position: relative;
    overflow: hidden;
  }
  .quiet-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 70% 50%, rgba(106,122,98,.12) 0%, transparent 60%);
    pointer-events: none;
  }
  .quiet-inner {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .quiet-inner h2 {
    font-family: var(--serif);
    font-size: clamp(2.4rem, 5vw, 5.2rem);
    font-weight: 300;
    line-height: 1.1;
    color: #fff;
    margin-bottom: 2rem;
  }
  .quiet-inner > p {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 300;
    font-style: italic;
    color: var(--stone-light);
    line-height: 1.9;
    max-width: 600px;
    margin-bottom: 2.5rem;
  }
  .quiet-cta {
    font-family: var(--sans);
    font-size: .58rem;
    font-weight: 300;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: rgba(255,255,255,.6);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    border-bottom: 1px solid rgba(255,255,255,.25);
    padding-bottom: 2px;
    margin-bottom: 5rem;
    transition: color .2s, border-color .2s;
  }
  .quiet-cta:hover { color: #fff; border-color: rgba(255,255,255,.6); }
  .quiet-compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: 1px solid var(--border-dark);
  }
  .quiet-compare-item {
    padding: 2.5rem 0;
    padding-right: 3rem;
  }
  .quiet-compare-item + .quiet-compare-item {
    border-left: 1px solid var(--border-dark);
    padding-left: 3rem;
    padding-right: 0;
  }
  .q-label {
    font-family: var(--sans);
    font-size: .52rem;
    font-weight: 200;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: rgba(255,255,255,.25);
    margin-bottom: .8rem;
    display: block;
  }
  .q-desc {
    font-family: var(--serif);
    font-size: .95rem;
    font-weight: 300;
    font-style: italic;
    color: rgba(255,255,255,.5);
    line-height: 1.7;
  }

  /* ───── FOOTER ───── */
  footer {
    background: var(--navy);
    border-top: 1px solid var(--border-dark);
    padding: 4rem 5vw 3rem;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }
  .footer-brand .footer-logo {
    font-family: var(--serif);
    font-size: 1.1rem;
    font-weight: 300;
    color: #fff;
    text-decoration: none;
    display: block;
    margin-bottom: .3rem;
  }
  .footer-brand .footer-tagline {
    font-family: var(--sans);
    font-size: .5rem;
    font-weight: 200;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: rgba(255,255,255,.25);
    display: block;
    margin-bottom: 1.5rem;
  }
  .footer-brand p {
    font-family: var(--serif);
    font-size: .88rem;
    font-weight: 300;
    font-style: italic;
    color: rgba(255,255,255,.35);
    line-height: 1.75;
  }
  .footer-col-label {
    font-family: var(--sans);
    font-size: .5rem;
    font-weight: 200;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: rgba(255,255,255,.25);
    display: block;
    margin-bottom: 1.4rem;
  }
  .footer-nav {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: .85rem;
  }
  .footer-nav a {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 300;
    color: rgba(255,255,255,.55);
    text-decoration: none;
    transition: color .2s;
  }
  .footer-nav a:hover { color: #fff; }
  .footer-bottom {
    border-top: 1px solid var(--border-dark);
    padding-top: 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .footer-bottom p {
    font-family: var(--sans);
    font-size: .54rem;
    font-weight: 200;
    letter-spacing: .1em;
    color: rgba(255,255,255,.2);
  }
  .footer-bottom a {
    font-family: var(--sans);
    font-size: .54rem;
    font-weight: 300;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: rgba(255,255,255,.3);
    text-decoration: none;
    transition: color .2s;
  }
  .footer-bottom a:hover { color: rgba(255,255,255,.65); }

  /* ───── MOBILE ───── */
  @media (max-width: 900px) {
    .nav-links { display: none; }
    .spring-section { grid-template-columns: 1fr; }
    .spring-image { height: 55vw; }
    .spring-content { padding: 3.5rem 5vw; }
    .kitchen-products { grid-template-columns: 1fr; }
    .kitchen-product-card { grid-template-columns: 1fr; min-height: auto; }
    .kitchen-product-card .k-card-img { height: 55vw; }
    .kitchen-product-card.full { grid-template-columns: 1fr; }
    .trust-pillars { grid-template-columns: 1fr; gap: 1.5rem; }
    .quiet-compare { grid-template-columns: 1fr; }
    .quiet-compare-item + .quiet-compare-item { border-left: none; border-top: 1px solid var(--border-dark); padding-left: 0; }
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
    .footer-grid .footer-brand { grid-column: 1 / -1; }
  }

  @media (max-width: 600px) {
    .footer-grid { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; gap: 1rem; text-align: center; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="index.html" class="nav-logo">
    She's the Goose
    <span>A Curated Life, Well Lived</span>
  </a>
  <div class="nav-right">
    <ul class="nav-links">
      <li><a href="finds.html">Finds</a></li>
      <li><a href="about.html">About</a></li>
    </ul>
    <div class="nav-sister"><a href="https://thequietledger.co" target="_blank">The Quiet Ledger →</a></div>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg" id="heroBg"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <span class="hero-eyebrow">She's the Goose</span>
    <h1 class="hero-headline">
      The home.<br>
      The table.<br>
      The kitchen.<br>
      <em>Done well.</em>
    </h1>
    <a href="#spring" class="hero-cta">Explore the Finds</a>
  </div>
</section>

<!-- RIGHT NOW: SPRING -->
<section class="spring-section" id="spring">
  <div class="spring-image">
    <img src="IMG_1672.jpeg" alt="Spring table with floral plates, vegan leather placemats, and lemons" loading="lazy">
  </div>
  <div class="spring-content">
