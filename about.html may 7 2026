<style>
  :root {
    --cream: #F2EDE4;
    --parchment: #EDE7DC;
    --ink: #1A1714;
    --ink-light: #58524A;
    --stone: #8C7E6E;
    --stone-light: #B5A898;
    --terracotta: #8A5A42;
