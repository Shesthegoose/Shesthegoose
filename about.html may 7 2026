    font-size: 1.22rem;
    font-weight: 300;
    font-style: italic;
    color: var(--ink-light);
    line-height: 2.3;
    margin-bottom: 2rem;
  }
  .letter p:last-of-type {
    margin-bottom: 4rem;
  }
  .inline-link {
    color: var(--terracotta);
    text-decoration: none;
    font-style: italic;
    border-bottom: 1px solid rgba(138,90,66,.25);
